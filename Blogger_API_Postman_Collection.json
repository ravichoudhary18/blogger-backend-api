                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access) {",
                                    "    pm.environment.set(\"accessToken\", jsonData.access);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
